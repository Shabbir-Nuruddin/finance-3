# Optional — enables live Claude responses in the AI Planner.
# Without it, the app uses a built-in deterministic engine so the demo always works.
ANTHROPIC_API_KEY=

# Optional — override the model (defaults to claude-haiku-4-5-20251001 for speed).
# For higher-quality answers during judging, try: claude-sonnet-4-6
ANTHROPIC_MODEL=
